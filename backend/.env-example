# === API KEYS ===
GEMINI_API_KEY='TU_CLAVE_GOOGLE_GEMINI'
OPENAI_API_KEY='TU_CLAVE_OPENAI'

# === CONFIGURACIÓN DEL SERVIDOR ===
PORT=3001
SERVER_URL=http://localhost:3001
# URL pública para Meta (ngrok o dominio real)
PUBLIC_BASE_URL=https://tu-dominio.com/image_creator/
# Carpeta física en Windows que sirve la URL anterior (Puente de Publicación)
PUBLIC_IMAGES_DIR='C:\\Ruta\\A\\Tu\\Carpeta\\Publica\\image_creator'

# === AUTO-PILOT & EMAIL ===
ADMIN_EMAIL='tu-email@gmail.com'
SMTP_USER='tu-email@gmail.com'
SMTP_PASS='tu-clave-de-aplicacion-google'

# === INSTAGRAM API (Meta For Developers) ===
INSTAGRAM_ACCESS_TOKEN='TU_TOKEN_DE_ACCESO_LARGA_DURACION'
INSTAGRAM_ACCOUNT_ID=TU_ID_DE_CUENTA_INSTAGRAM_BUSINESS

# === MODELOS IA ===
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
GEMINI_TEXT_GROUNDING_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_VIDEO_MODEL=veo-3.1-lite-generate-preview
GEMINI_AUDIO_MODEL=gemini-3-flash-preview

OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_EDIT_MODEL=gpt-image-2

# === BASE DE DATOS MYSQL (FullAgro) ===
MYSQL_HOST='localhost'
MYSQL_PORT=3307
MYSQL_USER='root'
MYSQL_PASSWORD='tu-password'
MYSQL_DATABASE=fullagro

# === INTEGRACIÓN HELPMEAGRO ===
HELPMEAGRO_PUBLIC_URL=https://www.helpmeagro.com
HELPMEAGRO_NEWS_PATH=/noticias/
NOTICE_IMAGES_DIR='C:\\Ruta\\notice_images\\'

# === CONFIGURACIÓN AGRO (AUTO-DAILY) ===
AGRO_PRICE_CARD_COUNT=6
AGRO_PRICE_CARD_OUTPUT_DIR=output/agro/
AGRO_DAILY_CRON_HOUR=08:00
